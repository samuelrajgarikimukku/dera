# Include essential files
include LICENSE
include README.md

# Include Python files and compiled web assets
recursive-include backend *.py
recursive-include backend/dist *

# Prune development and source directories
prune .github
prune node_modules
prune src
prune public
prune scratch

# Exclude individual config and scratch files
exclude package.json
exclude package-lock.json
exclude vite.config.js
exclude eslint.config.js
exclude index.html
exclude search_dataset.py
exclude search_exact_errors.py
exclude backend/migrateProjects.js

# Exclude compiler outputs and cache directories
global-exclude *.pyc
global-exclude __pycache__
global-exclude .git*
global-exclude .DS_Store
